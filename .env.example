# switch-killswitch configuration — copy to .env and fill in.
# The service needs no files at all: everything comes from these variables.

# ---- required -------------------------------------------------------------
# Switches and the ports the killswitch may shut:
# `name@ip:if1,if2` entries separated by `;` (verify ifIndexes with an ifDescr walk)
SWITCHES=core@192.0.2.10:24

# SNMPv3 credentials (a dedicated user on the switch with write access to
# ifAdminStatus — ideally nothing else)
SNMP_AUTH_PASSWORD=change-me-auth
SNMP_PRIV_PASSWORD=change-me-priv

# ---- snmp (defaults shown) --------------------------------------------------
#SNMP_USER=portshut-user
#SNMP_AUTH_PROTOCOL=SHA        # MD5 | SHA | SHA224 | SHA256 | SHA384 | SHA512
#SNMP_PRIV_PROTOCOL=DES        # DES | AES | AES192 | AES256 — match the switch
#SNMP_PORT=161

# ---- behaviour --------------------------------------------------------------
#POLL_INTERVAL=0.5             # seconds between polls (min 0.2)
#ARM_DELAY=30                  # port must be up this long before instant kills;
#                              # links often bounce once right after re-enable
#ARM_PERSIST=5                 # while settling, a drop must last this long to kill
#DEBOUNCE_SECONDS=10           # per-port cooldown between actions
#KILL_DELAY=0                  # 0 = primary; a few seconds on redundant standbys
#RATE_MAX_ACTIONS=10           # global storm guard...
#RATE_PER_SECONDS=60           # ...at most this many actions per window

# ---- notifications: email ----------------------------------------------------
#EMAIL_ENABLED=true
#SMTP_HOST=localhost
#SMTP_PORT=25
#SMTP_SECURITY=none            # none | starttls | ssl
#SMTP_USERNAME=                # empty = no auth
#SMTP_PASSWORD=
#SMTP_FROM=killswitch@localhost
#SMTP_TO=alerts@example.com    # comma-separated for multiple recipients
#SMTP_SUBJECT_PREFIX=[killswitch]

# ---- notifications: home assistant -------------------------------------------
#HA_ENABLED=false
#HA_BASE_URL=http://homeassistant.local:8123
#HA_TOKEN=                     # long-lived access token (HA profile -> Security)
#HA_EVENT_TYPE=switch_killswitch

# ---- home assistant control (MQTT): see + toggle ports from HA ----------------
# Exposes each watched port to Home Assistant as an MQTT-discovery switch entity
# you can see and toggle. Outbound-only (connects out to your broker; opens no
# inbound port). Needs an MQTT broker HA also talks to (e.g. the Mosquitto
# add-on). Every toggle is announced as port_restored/port_disabled, so manual
# re-enables stay auditable alongside kills.
#
# Running redundant instances? Enable this on ONE of them (the primary). It's a
# visibility/control convenience, not the safety-critical kill path, so it does
# not need N-way redundancy; a single owner avoids a shared availability topic
# flapping the entity. (If you do enable it on several, set a distinct
# MQTT_CLIENT_ID per instance — a broker force-disconnects duplicate client ids —
# and toggles are still deduped so only one instance acts.)
#MQTT_ENABLED=false
#MQTT_HOST=homeassistant.local # broker host (required when MQTT_ENABLED=true)
#MQTT_PORT=1883
#MQTT_USERNAME=                # empty = anonymous
#MQTT_PASSWORD=
#MQTT_TLS=false               # true to connect with TLS (typically port 8883)
#MQTT_CLIENT_ID=              # blank = switch-killswitch-<hostname> (unique per host)
#MQTT_DISCOVERY_PREFIX=homeassistant   # must match HA's MQTT discovery prefix
#MQTT_BASE_TOPIC=switch_killswitch
#MQTT_DEVICE_NAME=Switch Killswitch
#MQTT_ALLOW_REENABLE=true     # allow HA to re-enable a killed port
#MQTT_ALLOW_DISABLE=true      # allow HA to shut a port on demand
#                             # set both to false for a visibility-only entity
